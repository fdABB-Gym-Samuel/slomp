    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.1.11",
    "@types/bun": "^1.2.0",
    "svelte": "^5.30.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.1.11",
    "tslib": "^2.4.1",
    "typescript": "^5.6.0",
    "vite": "^6.2.0"
  }
}
